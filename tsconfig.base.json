{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@complihub/agent-core": [
                "packages/agent-core/src"
            ],
            "@complihub/agent-registry": [
                "packages/agent-registry/src"
            ],
            "@complihub/task-orchestrator": [
                "packages/task-orchestrator/src"
            ]
        },
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true
    }
}