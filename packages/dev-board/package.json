{
  "name": "@complihub/dev-board",
  "version": "0.1.0",
  "description": "Local Development Board & Process Launcher",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run start:server & npm run start:client",
    "start:server": "../../node_modules/.bin/tsx src/server/index.ts",
    "start:client": "../../node_modules/.bin/vite",
    "build": "../../node_modules/.bin/tsc && ../../node_modules/.bin/vite build",
    "lint": "../../node_modules/.bin/eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "../../node_modules/.bin/tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "chokidar": "^4.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.473.0",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.1",
    "typescript": "^5.5.3",
    "tsx": "^4.19.2",
    "tailwindcss": "^3.4.15",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "@types/node": "^22.0.0"
  }
}