{
  "name": "complihub360-alpha",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "description": "CompliHub360 - AI-Driven Compliance Platform",
  "workspaces": [
    "packages/*",
    "services/*",
    "ui/*"
  ],
  "lint": "eslint . --ext .ts,.tsx",
  "test": "npm run test --if-present --workspaces",
  "create:app": "node template/scripts/create-app.js",
  "format": "prettier --write .",
  "build": "tsc -b",
  "typecheck": "tsc -b",
  "clean": "tsc -b --clean"
},
"devDependencies": {
  "eslint": "^8.56.0",
  "prettier": "^3.2.4",
  "typescript": "^5.3.3"
}
}