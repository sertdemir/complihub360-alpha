{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "apps/vs1-demo/ui/Dockerfile.ui",
        "watchPatterns": [
            "apps/vs1-demo/ui/**",
            "packages/**"
        ]
    },
    "deploy": {
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
    }
}